# Stripe API keys (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring (monthly) Price ID for the optional brush subscription — accounts
# themselves are free and don't need Stripe at all. Create this under its own
# Product in the Stripe Dashboard (mode: subscription, not one-time), and make
# sure the webhook endpoint's subscribed events include
# customer.subscription.updated and customer.subscription.deleted, not just
# checkout.session.completed.
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# Session signing secret (generate a random 64-char hex string)
SESSION_SECRET=...

# Public URL of the deployed app (used in Stripe redirect URLs) — must include https://
APP_URL=https://your-app.up.railway.app

# Optional: lets people get free brush-subscriber status (no charge) by
# entering this code on signup, bypassing Stripe entirely. Accounts are free
# either way — this only grants the subscription. Omit this var to disable
# beta signup.
BETA_CODE=...

# Optional: enables DELETE /api/admin/users?email=... for removing test/spam
# accounts (this app has no admin role/dashboard — just this one secret-gated
# endpoint). Pass the same value as an X-Admin-Secret header:
#   curl -X DELETE "https://your-app/api/admin/users?email=test@example.com" \
#     -H "X-Admin-Secret: <this value>"
# Omit this var to disable the endpoint entirely (403).
ADMIN_SECRET=...

# Server port
PORT=3000

# Optional: sends a "new signup" notification email (via Resend, resend.com)
# every time a new account is created (free or beta). Omit RESEND_API_KEY to
# disable — signups still work fine, the email is just skipped (logged only).
RESEND_API_KEY=re_...
NOTIFY_EMAIL=heyrayinks@gmail.com
# Optional override for the "from" address — defaults to Resend's shared
# sandbox sender, which only works if NOTIFY_EMAIL is the Resend account's
# own verified address (no custom domain needed in that case).
NOTIFY_FROM_EMAIL=Exquisite Corpse <onboarding@resend.dev>
