# Stripe API keys (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Session signing secret (generate a random 64-char hex string)
SESSION_SECRET=...

# Public URL of the deployed app (used in Stripe redirect URLs) — must include https://
APP_URL=https://your-app.up.railway.app

# Optional: lets people create a paid account for free by entering this code on
# signup, bypassing Stripe entirely. Omit this var to disable beta signup.
BETA_CODE=...

# Server port
PORT=3000
